{
  "cli": {
    "version": ">=18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_TOW_D_API_URL": "https://api.thaistock2d.com",
        "EXPO_PUBLIC_THREE_D_API_URL": "https://api.2dboss.com/api/v2/v1/2dstock",
        "EXPO_PUBLIC_BACKEND_API_URL": "https://minkhant29.pythonanywhere.com/api",
        "EXPO_PUBLIC_DEFAULT_COMMISSION_PERCENT": "10",
        "EXPO_PUBLIC_DEFAULT_DRAW_TIMES": "80"
      },
      "channel": "apk"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
